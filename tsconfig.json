{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "ts-node": {
    "transpileOnly": true
  },
  "include": ["src/**/*", "tests/**/*"]
}
